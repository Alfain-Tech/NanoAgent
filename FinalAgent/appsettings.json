{
  "Application": {
    "ProductName": "FinalAgent",
    "StorageDirectoryName": "FinalAgent",
    "Conversation": {
      "RequestTimeoutSeconds": 30,
      "SystemPrompt": "You are FinalAgent, a careful CLI coding assistant. Give concise, actionable answers and prefer explicit reasoning over hidden magic."
    },
    "Defaults": {
      "Model": "gpt-5-mini"
    },
    "ModelSelection": {
      "CacheDurationSeconds": 300,
      "RankedPreferenceList": [
        "gpt-5",
        "gpt-5-mini",
        "gpt-4.1",
        "gpt-4.1-mini",
        "gpt-oss-20b",
        "qwen3-coder-30b",
        "qwen2.5-coder-7b-instruct",
        "phi-4-mini-reasoning",
        "gemma-4-31b-it"
      ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
